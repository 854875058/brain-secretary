# QQ Bridge -> Paperclip 示例环境变量
# 复制为本地 .env 或交给 systemd / shell 注入，勿提交真实值。

QQ_BOT_PAPERCLIP_ENABLED=true
QQ_BOT_PAPERCLIP_API_BASE_URL=http://127.0.0.1:3100
QQ_BOT_PAPERCLIP_COMPANY_ID=
QQ_BOT_PAPERCLIP_API_KEY=
QQ_BOT_PAPERCLIP_AUTH_COOKIE=
QQ_BOT_PAPERCLIP_DEFAULT_ASSIGNEE_AGENT_ID=
QQ_BOT_PAPERCLIP_TIMEOUT_SECONDS=30
