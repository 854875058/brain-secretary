{
  "project": {
    "name": "Brain Secretary",
    "service_chain": "QQ Bot (qqbot/default) -> OpenClaw(qq-main) -> child agents",
    "repo_root": ".",
    "primary_docs": {
      "handover": "HANDOVER.md",
      "setup": "SETUP.md",
      "systemd_ops": "docs/systemd-ops.md",
      "claude_rules": "CLAUDE.md"
    }
  },
  "models": {
    "primary_brain": {
      "runtime": "OpenClaw Agent",
      "agent_id": "qq-main",
      "thinking": "low",
      "model": "vllm/gpt-5.4",
      "child_agents": [
        {
          "agent_id": "brain-secretary-dev",
          "workspace": "/root/brain-secretary",
          "role": "primary engineering subagent"
        }
      ],
      "model_proxy_requirement": "proxy must preserve messages and tools for OpenClaw tool calling",
      "channel_entry": "qqbot/default -> qq-main",
      "bindings": [
        "qqbot:default"
      ]
    },
    "fallback_api": {
      "runtime": "Penguin API",
      "model": "claude-sonnet-4-6"
    }
  },
  "paths": {
    "ops_script": "scripts/ops_manager.py",
    "ops_manifest": "ops/deployment_manifest.json",
    "openclaw_config": "/root/.openclaw/openclaw.json",
    "openclaw_channel_plugin": "/root/.openclaw/extensions/qqbot",
    "openclaw_channel_plugin_source": "npm",
    "openclaw_channel_plugin_spec": "@openclaw-china/qqbot",
    "openclaw_brain_workspace": "/root/.openclaw/workspace",
    "model_proxy_script": "/root/.openclaw/model-proxy.mjs",
    "model_proxy_env": "/root/.openclaw/model-proxy.env",
    "public_proxy_config": "/etc/nginx/sites-available/openclaw-public.conf",
    "project_memory": "MEMORY.md",
    "fine_grained_memory": "memory",
    "legacy_qq_bridge_entry": "qq-bot/main.py",
    "legacy_qq_bridge_config": "qq-bot/config.yaml",
    "legacy_qq_bridge_logs": "qq-bot/logs",
    "legacy_napcat_start_script": "/root/Napcat/start-qq.sh"
  },
  "platforms": {
    "linux": {
      "deployment_mode": "systemd-user + system-nginx + OpenClaw qqbot channel",
      "groups": {
        "frontend": [
          "public_proxy"
        ],
        "backend": [
          "model_proxy",
          "gateway"
        ],
        "all": [
          "model_proxy",
          "gateway",
          "public_proxy"
        ]
      },
      "usage_examples": [
        "python3 scripts/ops_manager.py info",
        "python3 scripts/ops_manager.py status all",
        "python3 scripts/ops_manager.py restart backend",
        "python3 scripts/ops_manager.py restart public_proxy",
        "python3 scripts/ops_manager.py logs gateway -n 80",
        "openclaw channels list",
        "openclaw agents bindings --json"
      ],
      "components": {
        "model_proxy": {
          "unit": "openclaw-model-proxy.service",
          "script": "/root/.openclaw/model-proxy.mjs",
          "env_file": "/root/.openclaw/model-proxy.env",
          "compatibility_note": "must not strip OpenClaw tool-calling fields"
        },
        "gateway": {
          "unit": "openclaw-gateway.service",
          "ports": [
            {
              "name": "dashboard_internal",
              "host": "127.0.0.1",
              "port": 18789
            }
          ],
          "config_path": "/root/.openclaw/openclaw.json",
          "agents": [
            {
              "agent_id": "qq-main",
              "workspace": "/root/.openclaw/workspace",
              "role": "brain"
            },
            {
              "agent_id": "brain-secretary-dev",
              "workspace": "/root/brain-secretary",
              "role": "engineering"
            }
          ]
        },
        "public_proxy": {
          "unit": "nginx.service",
          "system_scope": true,
          "config_path": "/etc/nginx/sites-available/openclaw-public.conf",
          "ports": [
            {
              "name": "public_http",
              "host": "110.41.170.155",
              "port": 80
            }
          ],
          "routes": {
            "/": "http://127.0.0.1:18789",
            "/chat-history": "410 retired after qqbot migration",
            "/api/chat-history": "410 retired after qqbot migration"
          }
        }
      },
      "extra_locations": {
        "user_systemd_dir": "/root/.config/systemd/user"
      }
    },
    "windows": {
      "deployment_mode": "OpenClaw gateway + qqbot channel (manual/compat)",
      "groups": {
        "backend": [
          "gateway"
        ],
        "all": [
          "gateway"
        ]
      },
      "usage_examples": [
        "py -3 scripts\\ops_manager.py info",
        "py -3 scripts\\ops_manager.py status all",
        "py -3 scripts\\ops_manager.py start all",
        "py -3 scripts\\ops_manager.py restart backend"
      ],
      "components": {
        "gateway": {
          "ports": [
            {
              "name": "dashboard",
              "host": "127.0.0.1",
              "port": 18789
            }
          ],
          "start_hint": "openclaw gateway"
        }
      }
    }
  },
  "components": {
    "model_proxy": {
      "label": "OpenClaw Model Proxy",
      "description": "OpenClaw 模型兼容代理"
    },
    "gateway": {
      "label": "OpenClaw Gateway",
      "description": "OpenClaw 主网关 / 控制面板",
      "bindings": [
        {
          "channel": "qqbot",
          "account_id": "default",
          "agent_id": "qq-main"
        }
      ],
      "channels": [
        {
          "channel": "qqbot",
          "account_id": "default",
          "status": "enabled",
          "plugin_source": "npm",
          "plugin_spec": "@openclaw-china/qqbot",
          "markdown_support": false
        }
      ]
    },
    "public_proxy": {
      "label": "Public Reverse Proxy",
      "description": "Nginx public entry for OpenClaw dashboard and chat history",
      "routes": {
        "/": "http://127.0.0.1:18789",
        "/chat-history": "410 retired after qqbot migration",
        "/api/chat-history": "410 retired after qqbot migration"
      }
    }
  }
}
