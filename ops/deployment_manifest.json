{
  "project": {
    "name": "Brain Secretary",
    "service_chain": "QQ Bot (qqbot/default) -> OpenClaw(qq-main) -> child agents; auto evolve daemon -> OpenClaw(auto-evolve-main) -> child agents -> Paperclip control plane + projection",
    "repo_root": ".",
    "primary_docs": {
      "handover": "HANDOVER.md",
      "setup": "SETUP.md",
      "systemd_ops": "docs/systemd-ops.md",
      "claude_rules": "CLAUDE.md",
      "project_sync": "docs/project-sync-branch-workflow.md",
      "agent_team_state_graph": "docs/agent-team-state-graph.md"
    },
    "project_sync_config": "ops/project-sync.json",
    "project_registry": "ops/project_registry.json",
    "auto_evolve_config": "ops/auto-evolve.json",
    "auto_evolve_daemon_script": "scripts/project_auto_evolve_daemon.py",
    "auto_evolve_apply_script": "scripts/project_auto_evolve_apply.sh",
    "auto_evolve_systemd_unit": "ops/systemd/openclaw-project-auto-evolve.service",
    "branch_guard_script": "scripts/git_branch_guard.py",
    "auto_evolve_reconcile_script": "scripts/reconcile_auto_evolve_agent.py",
    "agent_team_core_module": "qq-bot/bot/agent_team.py",
    "private_kb_module": "qq-bot/bot/private_kb.py",
    "agent_team_demo_script": "scripts/agent_team_demo.py"
  },
  "models": {
    "primary_brain": {
      "runtime": "OpenClaw Agent",
      "agent_id": "qq-main",
      "thinking": "low",
      "model": "penguin/claude-sonnet-4-6",
      "child_agents": [
        {
          "agent_id": "brain-secretary-dev",
          "workspace": "/root/brain-secretary",
          "role": "primary engineering subagent"
        },
        {
          "agent_id": "brain-secretary-review",
          "workspace": "/root/brain-secretary",
          "role": "review and acceptance subagent"
        }
      ],
      "model_proxy_requirement": "proxy must preserve messages and tools for OpenClaw tool calling",
      "channel_entry": "qqbot/default -> qq-main",
      "bindings": [
        "qqbot:default"
      ],
      "provider_note": "2026-03-10 起默认从 gpt-5.1 切到 claude-sonnet-4-6，原因是上游 distributor 多次返回 503 No available channel"
    },
    "fallback_api": {
      "runtime": "OpenAI-compatible distributor (optional)",
      "model": "gpt-5.1",
      "status": "unstable: upstream may return 503 No available channel"
    },
    "auto_evolve_brain": {
      "runtime": "OpenClaw Agent",
      "agent_id": "auto-evolve-main",
      "thinking": "low",
      "model": "penguin/claude-sonnet-4-6",
      "role": "internal auto-evolve coordinator",
      "workspace": "/root/.openclaw/workspace",
      "child_agents": [
        {
          "agent_id": "brain-secretary-dev",
          "workspace": "/root/brain-secretary",
          "role": "primary engineering subagent"
        },
        {
          "agent_id": "brain-secretary-review",
          "workspace": "/root/brain-secretary",
          "role": "review and acceptance subagent"
        }
      ],
      "note": "must not be bound to qqbot/default; reserved for project auto evolve only"
    }
  },
  "paths": {
    "ops_script": "scripts/ops_manager.py",
    "ops_manifest": "ops/deployment_manifest.json",
    "openclaw_config": "/root/.openclaw/openclaw.json",
    "openclaw_channel_plugin": "/root/.openclaw/extensions/qqbot",
    "openclaw_channel_plugin_source": "npm",
    "openclaw_channel_plugin_spec": "@openclaw-china/qqbot",
    "openclaw_brain_workspace": "/root/.openclaw/workspace",
    "model_proxy_script": "/root/.openclaw/model-proxy.mjs",
    "model_proxy_env": "/root/.openclaw/model-proxy.env",
    "public_proxy_config": "/etc/nginx/sites-available/openclaw-public.conf",
    "project_memory": "MEMORY.md",
    "fine_grained_memory": "memory",
    "agent_team_doc": "docs/agent-team-state-graph.md",
    "agent_team_core_module": "qq-bot/bot/agent_team.py",
    "private_kb_module": "qq-bot/bot/private_kb.py",
    "agent_team_demo_script": "scripts/agent_team_demo.py",
    "legacy_qq_bridge_entry": "qq-bot/main.py",
    "legacy_qq_bridge_config": "qq-bot/config.yaml",
    "legacy_qq_bridge_logs": "qq-bot/logs",
    "legacy_napcat_start_script": "/root/Napcat/start-qq.sh",
    "napcat_multi_script": "scripts/napcat_multi.py",
    "napcat_multi_root": "/root/napcat-multi",
    "qq_bot_multi_script": "scripts/qq_bot_multi.py",
    "qq_bot_multi_root": "/root/qq-bot-multi",
    "windows_local_qq_multi_script": "scripts/windows_local_qq_multi.ps1",
    "windows_local_qq_multi_doc": "docs/windows-local-qq-multi.md",
    "windows_local_qq_profile_example": "ops/windows-local-qq-profile.example.json",
    "paperclip_repo": "/home/paperclip/paperclip",
    "paperclip_home": "/home/paperclip/paperclip-data",
    "paperclip_env": "/home/paperclip/paperclip/.env.local",
    "paperclip_local_env": "ops/paperclip.local.env",
    "paperclip_viewer_env": "/root/.config/brain-secretary/paperclip-viewer.env",
    "paperclip_public_proxy_config": "/etc/nginx/sites-available/paperclip-public.conf",
    "paperclip_bootstrap_script": "scripts/paperclip_bootstrap.sh",
    "paperclip_runtime_apply_script": "scripts/paperclip_runtime_apply.sh",
    "paperclip_seed_script": "scripts/paperclip_seed.py",
    "paperclip_cli_script": "scripts/paperclip_cli.py",
    "paperclip_ui_zh_patch_script": "scripts/paperclip_ui_zh_patch.py",
    "paperclip_projection_daemon_script": "scripts/paperclip_projection_daemon.py",
    "paperclip_projection_apply_script": "scripts/paperclip_projection_apply.sh",
    "paperclip_projection_systemd_unit": "ops/systemd/openclaw-paperclip-projection.service"
  },
  "platforms": {
    "linux": {
      "deployment_mode": "systemd-user(OpenClaw + projection + auto-evolve) + systemd(Paperclip) + system-nginx + OpenClaw qqbot channel",
      "groups": {
        "frontend": [
          "public_proxy",
          "paperclip_public_proxy"
        ],
        "backend": [
          "model_proxy",
          "gateway",
          "paperclip",
          "paperclip_projection",
          "project_auto_evolve"
        ],
        "all": [
          "model_proxy",
          "gateway",
          "paperclip",
          "paperclip_projection",
          "project_auto_evolve",
          "public_proxy",
          "paperclip_public_proxy"
        ]
      },
      "usage_examples": [
        "python3 scripts/ops_manager.py info",
        "python3 scripts/ops_manager.py status all",
        "python3 scripts/ops_manager.py restart backend",
        "python3 scripts/ops_manager.py restart public_proxy",
        "python3 scripts/ops_manager.py logs gateway -n 80",
        "openclaw channels list",
        "openclaw agents bindings --json",
        "python3 scripts/napcat_multi.py bootstrap --refresh-workdir",
        "python3 scripts/napcat_multi.py status --json",
        "python3 scripts/napcat_multi.py qr --json",
        "python3 scripts/qq_bot_multi.py bootstrap --json",
        "python3 scripts/qq_bot_multi.py status --json",
        "systemctl status paperclip.service",
        "journalctl -u paperclip.service -n 80 --no-pager",
        "python3 scripts/paperclip_seed.py --json",
        "python3 scripts/paperclip_cli.py status --json",
        "bash scripts/paperclip_projection_apply.sh",
        "python3 scripts/paperclip_projection_daemon.py once --json",
        "python3 scripts/ops_manager.py logs paperclip_projection -n 80",
        "python3 scripts/reconcile_auto_evolve_agent.py --json",
        "python3 scripts/project_auto_evolve_daemon.py status --json",
        "python3 scripts/project_auto_evolve_daemon.py doctor --json",
        "python3 scripts/project_auto_evolve_daemon.py watchdog --json",
        "python3 scripts/project_auto_evolve_daemon.py exceptions --json",
        "python3 scripts/project_auto_evolve_daemon.py once --project tower-eye --json",
        "bash scripts/project_auto_evolve_apply.sh",
        "python3 scripts/ops_manager.py logs project_auto_evolve -n 80",
        "python3 scripts/agent_team_demo.py --mode mock --json"
      ],
      "components": {
        "model_proxy": {
          "unit": "openclaw-model-proxy.service",
          "script": "/root/.openclaw/model-proxy.mjs",
          "env_file": "/root/.openclaw/model-proxy.env",
          "compatibility_note": "must not strip OpenClaw tool-calling fields"
        },
        "gateway": {
          "unit": "openclaw-gateway.service",
          "ports": [
            {
              "name": "dashboard_internal",
              "host": "127.0.0.1",
              "port": 18789
            }
          ],
          "config_path": "/root/.openclaw/openclaw.json",
          "agents": [
            {
              "agent_id": "qq-main",
              "workspace": "/root/.openclaw/workspace",
              "role": "brain"
            },
            {
              "agent_id": "auto-evolve-main",
              "workspace": "/root/.openclaw/workspace",
              "role": "auto_evolve_brain"
            },
            {
              "agent_id": "brain-secretary-dev",
              "workspace": "/root/brain-secretary",
              "role": "engineering"
            },
            {
              "agent_id": "brain-secretary-review",
              "workspace": "/root/brain-secretary",
              "role": "review"
            }
          ]
        },
        "public_proxy": {
          "unit": "nginx.service",
          "system_scope": true,
          "config_path": "/etc/nginx/sites-available/openclaw-public.conf",
          "ports": [
            {
              "name": "public_http",
              "host": "110.41.170.155",
              "port": 80
            }
          ],
          "routes": {
            "/": "http://127.0.0.1:18789",
            "/chat-history": "410 retired after qqbot migration",
            "/api/chat-history": "410 retired after qqbot migration",
            "/paperclip/": "http://127.0.0.1:3110 (basic auth, nginx rewrite prefix)"
          }
        },
        "paperclip": {
          "unit": "paperclip.service",
          "working_directory": "/home/paperclip/paperclip",
          "env_file": "/home/paperclip/paperclip/.env.local",
          "runtime_user": "paperclip",
          "ports": [
            {
              "name": "api",
              "host": "127.0.0.1",
              "port": 3110
            }
          ],
          "viewer_credentials": "/root/.config/brain-secretary/paperclip-viewer.env"
        },
        "paperclip_public_proxy": {
          "unit": "nginx.service",
          "config_path": "/etc/nginx/sites-available/paperclip-public.conf",
          "ports": [
            {
              "name": "paperclip_viewer",
              "host": "0.0.0.0",
              "port": 3100
            }
          ],
          "preferred_public_url": "http://110.41.170.155/paperclip/",
          "legacy_public_url": "http://110.41.170.155:3100",
          "note": "legacy :3100 listener is still configured, but cloud-side ingress is currently not open"
        },
        "paperclip_projection": {
          "unit": "openclaw-paperclip-projection.service",
          "script": "/root/brain-secretary/scripts/paperclip_projection_daemon.py",
          "transcript_dirs": [
            "/root/.openclaw/agents/qq-main/sessions",
            "/root/.openclaw/agents/auto-evolve-main/sessions"
          ]
        },
        "project_auto_evolve": {
          "unit": "openclaw-project-auto-evolve.service",
          "script": "/root/brain-secretary/scripts/project_auto_evolve_daemon.py",
          "config_path": "/root/brain-secretary/ops/auto-evolve.json",
          "project_sync_config": "/root/brain-secretary/ops/project-sync.json",
          "agent_id": "auto-evolve-main"
        }
      },
      "extra_locations": {
        "user_systemd_dir": "/root/.config/systemd/user",
        "napcat_multi_root": "/root/napcat-multi"
      },
      "auxiliary": {
        "napcat_multi_examples": {
          "script": "/root/brain-secretary/scripts/napcat_multi.py",
          "root": "/root/napcat-multi",
          "instances": [
            {
              "slug": "brain",
              "role": "大脑号",
              "agent_id": "qq-main",
              "webui_port": 6101,
              "onebot_port": 3001
            },
            {
              "slug": "tech",
              "role": "技术号",
              "agent_id": "brain-secretary-dev",
              "webui_port": 6102,
              "onebot_port": 3002
            },
            {
              "slug": "review",
              "role": "方案验收号",
              "agent_id": "brain-secretary-review",
              "webui_port": 6103,
              "onebot_port": 3003
            }
          ]
        },
        "qq_bridge_multi_examples": {
          "script": "/root/brain-secretary/scripts/qq_bot_multi.py",
          "root": "/root/qq-bot-multi",
          "instances": [
            {
              "slug": "brain",
              "role": "大脑号",
              "agent_id": "qq-main",
              "bridge_port": 8011,
              "onebot_port": 3001
            },
            {
              "slug": "tech",
              "role": "技术号",
              "agent_id": "brain-secretary-dev",
              "bridge_port": 8012,
              "onebot_port": 3002
            },
            {
              "slug": "review",
              "role": "方案验收号",
              "agent_id": "brain-secretary-review",
              "bridge_port": 8013,
              "onebot_port": 3003
            }
          ]
        }
      }
    },
    "windows": {
      "deployment_mode": "OpenClaw gateway + qqbot channel (manual/compat)",
      "groups": {
        "backend": [
          "gateway"
        ],
        "all": [
          "gateway"
        ]
      },
      "usage_examples": [
        "py -3 scripts\\ops_manager.py info",
        "py -3 scripts\\ops_manager.py status all",
        "py -3 scripts\\ops_manager.py start all",
        "py -3 scripts\\ops_manager.py restart backend",
        "scripts\\windows_local_qq_quick_setup.bat",
        "powershell -ExecutionPolicy Bypass -File scripts\\windows_local_qq_multi.ps1 -ServerBridgeHost <server-host>",
        "powershell -ExecutionPolicy Bypass -File scripts\\windows_local_qq_doctor.ps1 -ServerBridgeHost <server-host>",
        "python3 scripts/qq_bot_multi.py print-example",
        "powershell -ExecutionPolicy Bypass -File scripts\\windows_local_qq_remote_apply.ps1 -ServerSshTarget <root@server>",
        "python3 scripts/project_sync.py sync --config ops/project-sync.json --project my-app",
        "python3 scripts/project_sync.py prepare-work --config ops/project-sync.json --project multimodal-retrieval",
        "python3 scripts/project_sync.py prepare-agent --config ops/project-sync.json --project multimodal-retrieval",
        "python3 scripts/project_sync.py promote-agent --config ops/project-sync.json --project multimodal-retrieval",
        "powershell -ExecutionPolicy Bypass -File scripts\\windows_project_autosync.ps1 -Project multimodal-retrieval -IntervalSeconds 120",
        "py -3 scripts\\agent_team_demo.py --mode mock --json"
      ],
      "components": {
        "gateway": {
          "ports": [
            {
              "name": "dashboard",
              "host": "127.0.0.1",
              "port": 18789
            }
          ],
          "start_hint": "openclaw gateway"
        }
      },
      "auxiliary": {
        "local_multi_qq": {
          "mode": "Windows local QQ + NapCat, server-side bridge + OpenClaw",
          "windows_quick_setup_bat": "scripts/windows_local_qq_quick_setup.bat",
          "windows_script": "scripts/windows_local_qq_multi.ps1",
          "windows_doctor_ps1": "scripts/windows_local_qq_doctor.ps1",
          "windows_doctor_bat": "scripts/windows_local_qq_doctor.bat",
          "default_output_root": "%USERPROFILE%\\brain-secretary-local-qq",
          "server_bridge_script": "scripts/qq_bot_multi.py",
          "doc": "docs/windows-local-qq-multi.md",
          "profile_example": "ops/windows-local-qq-profile.example.json",
          "bridge_ports": [
            8011,
            8012,
            8013
          ],
          "onebot_ports": [
            3001,
            3002,
            3003
          ],
          "agent_map": {
            "brain": "qq-main",
            "tech": "brain-secretary-dev",
            "review": "brain-secretary-review"
          },
          "windows_remote_apply_ps1": "scripts/windows_local_qq_remote_apply.ps1",
          "memory_center_script": "scripts/memory_center.py",
          "project_sync_script": "scripts/project_sync.py",
          "project_sync_doc": "docs/project-sync-branch-workflow.md",
          "project_autosync_ps1": "scripts/windows_project_autosync.ps1",
          "project_autosync_bat": "scripts/windows_project_autosync.bat"
        }
      }
    }
  },
  "components": {
    "model_proxy": {
      "label": "OpenClaw Model Proxy",
      "description": "OpenClaw 模型兼容代理"
    },
    "gateway": {
      "label": "OpenClaw Gateway",
      "description": "OpenClaw 主网关 / 控制面板",
      "bindings": [
        {
          "channel": "qqbot",
          "account_id": "default",
          "agent_id": "qq-main"
        }
      ],
      "channels": [
        {
          "channel": "qqbot",
          "account_id": "default",
          "status": "enabled",
          "plugin_source": "npm",
          "plugin_spec": "@openclaw-china/qqbot",
          "markdown_support": false
        }
      ]
    },
    "public_proxy": {
      "label": "Public Reverse Proxy",
      "description": "Nginx public entry for OpenClaw dashboard and chat history",
      "routes": {
        "/": "http://127.0.0.1:18789",
        "/chat-history": "410 retired after qqbot migration",
        "/api/chat-history": "410 retired after qqbot migration",
        "/paperclip/": "http://127.0.0.1:3110 (basic auth, nginx rewrite prefix)"
      }
    },
    "paperclip": {
      "label": "Paperclip Control Plane",
      "description": "Paperclip issue / heartbeat / web viewer control plane",
      "agents": [
        {
          "name": "qq-main",
          "session_key": "agent:qq-main:paperclip"
        },
        {
          "name": "brain-secretary-dev",
          "session_key": "agent:brain-secretary-dev:paperclip"
        },
        {
          "name": "brain-secretary-review",
          "session_key": "agent:brain-secretary-review:paperclip"
        }
      ]
    },
    "paperclip_public_proxy": {
      "label": "Paperclip Public Viewer",
      "description": "Nginx basic-auth protected Paperclip viewer",
      "routes": {
        "/": "http://127.0.0.1:3110"
      },
      "preferred_public_url": "http://110.41.170.155/paperclip/",
      "legacy_public_url": "http://110.41.170.155:3100",
      "note": "legacy :3100 listener is still configured, but cloud-side ingress is currently not open"
    },
    "paperclip_projection": {
      "label": "Paperclip Collaboration Projection",
      "description": "Auto-project qq-main and auto-evolve-main subagent collaboration into read-only Paperclip parent/child issues"
    },
    "project_auto_evolve": {
      "label": "Project Auto Evolution Daemon",
      "description": "Continuously drives auto-evolve-main to evolve registered projects on agent branches only, with qq-main session-pollution watchdog, structured-report contract, review evidence gate, and exceptions-only summary"
    }
  }
}
